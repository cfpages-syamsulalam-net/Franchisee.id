---
import {
  getCategoryRouteEntries,
  getRecommendedRows,
  loadFranchiseStaticRows,
  renderListingPage,
  type CategoryRouteEntry,
} from "../../lib/franchise-static";

export const prerender = true;

export function getStaticPaths() {
  const rows = loadFranchiseStaticRows();
  return getCategoryRouteEntries(rows).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CategoryRouteEntry };
const html = renderListingPage(entry.rows, {
  title: `Franchise ${entry.label}`,
  description: `Daftar peluang franchise kategori ${entry.label} yang tersedia di Franchisee.id, lengkap dengan informasi modal, profil brand, dan kontak franchisor bila tersedia.`,
  canonicalPath: entry.canonicalPath,
  rows: getRecommendedRows(entry.rows),
});
---
<Fragment set:html={html} />
