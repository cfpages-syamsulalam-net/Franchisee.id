---
export const prerender = true;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Menyelesaikan Login - Franchisee.id</title>
    <link rel="stylesheet" href="/css/auth-clerk.css">
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #f2f2f2;
        color: #171717;
        font-family: Outfit, "DM Sans", Arial, sans-serif;
      }
      .sso-card {
        width: min(92vw, 620px);
        border: 1px solid #e5e5e5;
        background: #ffffff;
        padding: 24px;
      }
      .sso-card h1 {
        margin: 0;
        font-size: 22px;
      }
      .sso-card p {
        color: #646464;
        line-height: 1.5;
      }
      .sso-debug {
        max-height: 320px;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-word;
        border: 1px solid #ededed;
        background: #f8f8f8;
        padding: 10px;
        font: 12px/1.45 Consolas, "Courier New", monospace;
      }
      .sso-copy {
        width: 36px;
        height: 36px;
        display: none;
        align-items: center;
        justify-content: center;
        border: 1px solid #dedede;
        border-radius: 4px;
        background: #f7f7f7;
        color: #111111;
        cursor: pointer;
      }
      .sso-copy.is-visible {
        display: inline-flex;
      }
      .sso-copy svg {
        width: 17px;
        height: 17px;
      }
    </style>
  </head>
  <body>
    <main class="sso-card">
      <h1>Menyelesaikan login...</h1>
      <p data-sso-status>Mohon tunggu. Jika halaman ini tidak berpindah otomatis, login Google belum selesai diproses oleh Clerk.</p>
      <button class="sso-copy" type="button" data-sso-copy aria-label="Copy auth debug" title="Copy auth debug">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M8 7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2V7Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <path d="M4 15V4a2 2 0 0 1 2-2h9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <pre class="sso-debug" data-sso-debug hidden>{}</pre>
    </main>

    <script src="/js/auth-clerk-debug.js" is:inline></script>
    <script src="/js/auth-clerk.js" is:inline></script>
    <script is:inline>
      (function () {
        var statusEl = document.querySelector("[data-sso-status]");
        var debugEl = document.querySelector("[data-sso-debug]");
        var copyButton = document.querySelector("[data-sso-copy]");
        window.FRANCHISE_AUTH_DEBUG = true;
        if (copyButton) copyButton.addEventListener("click", copyDebug);
        boot();

        async function boot() {
          try {
            if (!window.FranchiseAuth) throw new Error("Auth runtime belum tersedia.");
            await window.FranchiseAuth.init();
            var snapshot = getSnapshot();
            if (!snapshot || !snapshot.clerk || !snapshot.clerk.hasSession) {
              throw new Error("Clerk callback selesai, tetapi tidak ada session aktif di browser.");
            }
            window.location.replace(getPendingDestination());
          } catch (error) {
            if (statusEl) {
              statusEl.textContent = (error && error.message ? error.message : "Login Google gagal diproses.") + " Silakan kembali ke dashboard dan coba lagi.";
            }
            if (debugEl) {
              debugEl.hidden = false;
              if (copyButton) copyButton.classList.add("is-visible");
              debugEl.textContent = JSON.stringify(
                window.FranchiseAuth && typeof window.FranchiseAuth.getDebugSnapshot === "function"
                  ? window.FranchiseAuth.getDebugSnapshot()
                  : { error: error && error.message ? error.message : String(error) },
                null,
                2
              );
            }
          }
        }

        function getPendingDestination() {
          var snapshot = getSnapshot();
          var destination = snapshot && snapshot.storage ? snapshot.storage.pendingNext : "";
          return destination && destination.charAt(0) === "/" ? destination : "/dashboard";
        }

        function getSnapshot() {
          return window.FranchiseAuth && typeof window.FranchiseAuth.getDebugSnapshot === "function"
            ? window.FranchiseAuth.getDebugSnapshot()
            : null;
        }

        async function copyDebug() {
          if (!debugEl) return;
          var text = debugEl.textContent || "";
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(text);
          } else {
            var textarea = document.createElement("textarea");
            textarea.value = text;
            textarea.setAttribute("readonly", "readonly");
            textarea.style.position = "fixed";
            textarea.style.left = "-9999px";
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand("copy");
            textarea.remove();
          }
          if (statusEl) statusEl.textContent = "Auth debug copied. Paste it into the chat.";
        }
      }());
    </script>
  </body>
</html>
