---
import {
  getCategoryRouteEntries,
  getRecommendedRows,
  loadFranchiseStaticRows,
  renderListingPage,
  type CategoryRouteEntry,
} from "../lib/franchise-static";

export const prerender = true;

export function getStaticPaths() {
  const rows = loadFranchiseStaticRows();
  return getCategoryRouteEntries(rows).map((entry) => ({
    params: { categorySlug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CategoryRouteEntry };
const html = renderListingPage(entry.rows, {
  title: `Franchise ${entry.label}`,
  description: `Temukan peluang franchise ${entry.label} yang tersedia di Franchisee.id, termasuk estimasi modal, kategori usaha, profil brand, dan tautan detail franchise.`,
  canonicalPath: `/${entry.slug}`,
  rows: getRecommendedRows(entry.rows),
});
---
<Fragment set:html={html} />
