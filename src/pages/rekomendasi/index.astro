---
import { getRecommendedRows, loadFranchiseStaticRows, renderListingPage } from "../../lib/franchise-static";

export const prerender = true;

const rows = loadFranchiseStaticRows();
const html = renderListingPage(rows, {
  title: "Rekomendasi Franchise",
  description: "Rekomendasi franchise pilihan dari Franchisee.id berdasarkan kelengkapan profil, status verifikasi, kategori, modal, dan kualitas informasi publik.",
  canonicalPath: "/rekomendasi",
  rows: getRecommendedRows(rows),
});
---
<Fragment set:html={html} />
