---
import { getAlphabeticalRows, loadFranchiseStaticRows, renderListingPage } from "../../lib/franchise-static";

export const prerender = true;

const rows = loadFranchiseStaticRows();
const html = renderListingPage(rows, {
  title: "Kategori Franchise Berdasarkan Abjad",
  description: "Cari peluang franchise berdasarkan urutan abjad A sampai Z agar brand waralaba lebih mudah ditemukan dan dibandingkan.",
  canonicalPath: "/abjad",
  rows: getAlphabeticalRows(rows),
});
---
<Fragment set:html={html} />
