---
import { getPopularRows, loadFranchiseStaticRows, renderListingPage } from "../../lib/franchise-static";

export const prerender = true;

const rows = loadFranchiseStaticRows();
const html = renderListingPage(rows, {
  title: "Franchise Terlaris & Populer",
  description: "Daftar franchise populer yang disusun dari kualitas listing, kelengkapan informasi, kategori bisnis, dan sinyal publik yang tersedia di direktori Franchisee.id.",
  canonicalPath: "/populer",
  rows: getPopularRows(rows),
});
---
<Fragment set:html={html} />
