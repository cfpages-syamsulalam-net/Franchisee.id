---
import {
  getCategoryRouteEntries,
  getRecommendedRows,
  loadFranchiseStaticRows,
  renderListingPage,
  type CategoryRouteEntry,
} from "../../lib/franchise-static";

export const prerender = true;

export function getStaticPaths() {
  const rows = loadFranchiseStaticRows();
  return getCategoryRouteEntries(rows).map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CategoryRouteEntry };
const html = renderListingPage(entry.rows, {
  title: `Franchise ${entry.label}`,
  description: `Direktori franchise kategori ${entry.label}, disusun dari data D1 Franchisee.id agar peluang bisnis tetap mudah dicari dan dibandingkan.`,
  canonicalPath: `/category/${entry.slug}`,
  rows: getRecommendedRows(entry.rows),
});
---
<Fragment set:html={html} />
