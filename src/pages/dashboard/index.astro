---
export const prerender = true;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Dashboard Operasional - Franchisee.id</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/css/frontend.min.css">
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/lib/font-awesome/css/all.min.css?ver=3.32.3">
    <link rel="stylesheet" href="/css/auth-clerk.css">
    <link rel="stylesheet" href="/css/shared-tooltip.css">
    <link rel="stylesheet" href="/css/dashboard.css">
  </head>
  <body>
    <div class="dash-shell">
      <header class="dash-header">
        <div class="dash-header-inner">
          <div class="dash-title">
            <span class="dash-brand-mark" aria-hidden="true">F</span>
            <div>
              <p class="dash-kicker">Franchisee.id</p>
              <h1>Dashboard Operasional</h1>
              <p>Ruang kerja internal untuk menjaga listing, Premium, dan publikasi tetap rapi.</p>
            </div>
          </div>
          <div class="dash-user" data-dashboard-user>Memuat sesi...</div>
        </div>
      </header>

      <main class="dash-main" data-dashboard-protected="locked">
        <div class="dash-alert" data-dashboard-status>Memeriksa akses admin/staff...</div>

        <section class="dash-login-panel" data-dashboard-login aria-label="Login admin dan staff">
          <div id="franchise-auth-root" data-auth-mode="login" data-auth-variant="staff" data-auth-next="/dashboard/"></div>
          <div class="dash-debug-panel" data-auth-debug>
            <div class="dash-debug-head">
              <div>
                <strong>Auth Debug</strong>
                <span>Safe to screenshot: token values are masked.</span>
              </div>
              <div class="dash-debug-actions">
                <button class="dash-icon-button" type="button" data-auth-debug-copy aria-label="Salin debug login" data-fr-tooltip="Salin debug login">
                  <i class="fas fa-copy" aria-hidden="true"></i>
                </button>
                <button class="dash-icon-button dash-action-button" type="button" data-auth-debug-refresh aria-label="Refresh debug login" data-fr-tooltip="Refresh debug login">
                  <i class="fas fa-sync-alt" aria-hidden="true"></i>
                </button>
              </div>
            </div>
            <div class="dash-debug-body">
              <div class="dash-debug-summary" data-auth-debug-summary>Menunggu auth runtime...</div>
              <pre class="dash-debug-output" data-auth-debug-output>{}</pre>
            </div>
          </div>
        </section>

        <section class="dash-grid" aria-label="Ringkasan dashboard">
          <div class="dash-card"><span>Total listing</span><strong data-metric="total_listings">-</strong></div>
          <div class="dash-card"><span>Belum diklaim</span><strong data-metric="unclaimed_listings">-</strong></div>
          <div class="dash-card"><span>Terverifikasi</span><strong data-metric="verified_listings">-</strong></div>
          <div class="dash-card"><span>Pending publish</span><strong data-metric="pending_publish">-</strong></div>
        </section>

        <nav class="dash-tabs" role="tablist" aria-label="Dashboard sections" data-dashboard-tabs>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-outreach" aria-controls="dash-panel-outreach" aria-selected="true" data-dashboard-tab="outreach">
            <i class="fas fa-comments dash-tab-icon" aria-hidden="true"></i>
            Outreach
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-quality" aria-controls="dash-panel-quality" aria-selected="false" data-dashboard-tab="quality">
            <i class="fas fa-check-circle dash-tab-icon" aria-hidden="true"></i>
            Data Quality
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-review" aria-controls="dash-panel-review" aria-selected="false" data-dashboard-tab="review">
            <i class="fas fa-clipboard-check dash-tab-icon" aria-hidden="true"></i>
            Review
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-operations" aria-controls="dash-panel-operations" aria-selected="false" data-dashboard-tab="operations">
            <i class="fas fa-cogs dash-tab-icon" aria-hidden="true"></i>
            Operations
          </button>
        </nav>

        <section class="dash-tab-panels">
          <section class="dash-tab-panel" id="dash-panel-outreach" role="tabpanel" aria-labelledby="dash-tab-outreach" data-dashboard-panel="outreach">
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                  <i class="fas fa-comments dash-section-icon" aria-hidden="true"></i>
                  <div>
                    <h2>Unclaimed Outreach</h2>
                    <p>WhatsApp memakai nomor personal staff melalui link wa.me.</p>
                  </div>
                </div>
                <span class="dash-badge" data-outreach-count>-</span>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kontak</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-outreach-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat antrean outreach...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-quality" role="tabpanel" aria-labelledby="dash-tab-quality" data-dashboard-panel="quality" hidden>
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                    <i class="fas fa-check-circle dash-section-icon" aria-hidden="true"></i>
                  <div>
                    <h2>Data Quality</h2>
                    <p>Prioritas listing yang perlu dibersihkan.</p>
                  </div>
                </div>
                <div class="dash-actions dash-toolbar" role="toolbar" aria-label="Aksi data quality">
                  <button class="dash-icon-button dash-action-button" type="button" data-refresh-quality aria-label="Refresh quality checks" data-fr-tooltip="Refresh quality checks">
                    <i class="fas fa-sync-alt" aria-hidden="true"></i>
                  </button>
                </div>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kategori</th>
                      <th>Warning</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-quality-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat quality checks...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-review" role="tabpanel" aria-labelledby="dash-tab-review" data-dashboard-panel="review" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-edit dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2 data-edit-panel-title>Listing Edit Suggestions</h2>
                      <p data-edit-panel-copy>Staff menyiapkan perubahan; admin menyetujui sebelum tampil.</p>
                    </div>
                  </div>
                  <span class="dash-badge" data-edit-count>-</span>
                </div>
                <form class="dash-form" data-edit-form>
                  <label>
                    Listing
                    <select data-listing-select required>
                      <option value="">Memuat listing...</option>
                    </select>
                  </label>
                  <label>
                    Reason
                    <input type="text" data-edit-reason maxlength="1200" placeholder="Contoh: nomor kontak publik salah">
                  </label>
                  <div class="dash-form-wide dash-field-editor">
                    <div class="dash-field-editor-head">
                      <div>
                        <strong>Perubahan field</strong>
                        <span>Pilih field, isi nilai baru, lalu kirim sesuai akses akun.</span>
                      </div>
                      <button class="dash-icon-button dash-action-button" type="button" data-add-edit-field aria-label="Tambah field" data-fr-tooltip="Tambah field">
                        <i class="fas fa-plus" aria-hidden="true"></i>
                      </button>
                    </div>
                    <div class="dash-field-list" data-edit-field-list></div>
                  </div>
                  <div class="dash-form-wide dash-actions dash-toolbar" role="toolbar" aria-label="Aksi edit suggestion">
                    <button class="dash-icon-button dash-action-button is-primary" type="submit" data-edit-submit aria-label="Kirim saran edit" data-fr-tooltip="Kirim saran edit">
                      <i class="fas fa-paper-plane" aria-hidden="true"></i>
                    </button>
                    <span class="dash-muted" data-edit-help>Perubahan akan masuk review admin kecuali akun ini punya izin approve langsung.</span>
                  </div>
                </form>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Brand</th>
                        <th>Diff</th>
                        <th>Reason</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody data-edit-rows>
                      <tr><td colspan="4" class="dash-loading">Memuat edit suggestions...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-shield-alt dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Claim Review</h2>
                      <p>Admin menyetujui claim; staff hanya membantu review.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-claim-rows>
                  <li><span>Memuat claim pending...</span></li>
                </ul>
                <div class="dash-location-editor" data-location-editor>
                  <div class="dash-field-editor-head">
                    <div>
                      <strong>Area Listing</strong>
                      <span>Admin bisa memperbaiki kota tampil untuk halaman kota.</span>
                    </div>
                  </div>
                  <form class="dash-form dash-location-form" data-location-form>
                    <label class="dash-form-wide">
                      Listing
                      <select data-location-listing-select>
                        <option value="">Pilih listing...</option>
                      </select>
                    </label>
                    <label class="dash-form-wide">
                      Kota dan area
                      <textarea data-location-text rows="6" placeholder="Jakarta | area | DKI Jakarta&#10;Bandung | outlet | Jawa Barat"></textarea>
                    </label>
                    <p class="dash-muted dash-form-wide" data-location-help>Gunakan format: kota | jenis | provinsi. Jenis: area, outlet, kantor, asal.</p>
                    <div class="dash-form-wide dash-actions dash-toolbar" role="toolbar" aria-label="Aksi area listing">
                      <button class="dash-icon-button dash-action-button is-primary" type="submit" data-location-submit aria-label="Simpan area listing" data-fr-tooltip="Simpan area listing">
                        <i class="fas fa-map-location-dot" aria-hidden="true"></i>
                      </button>
                      <span class="dash-muted" data-location-current>Belum ada listing dipilih.</span>
                    </div>
                  </form>
                </div>
              </section>
            </div>
          </section>

          <section class="dash-tab-panel" id="dash-panel-operations" role="tabpanel" aria-labelledby="dash-tab-operations" data-dashboard-panel="operations" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-sync-alt dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Publish Queue</h2>
                      <p>Status pembaruan halaman franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-publish-state>
                  <li><span>Memuat publish state...</span></li>
                </ul>
              </section>

              <section class="dash-panel dash-panel-wide">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-network-wired dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Publikasi Network</h2>
                      <p>Atur tampil/sembunyi listing di situs yang tersedia.</p>
                    </div>
                  </div>
                </div>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Listing</th>
                        <th>Status per situs</th>
                      </tr>
                    </thead>
                    <tbody data-publication-rows>
                      <tr><td colspan="2" class="dash-empty">Memuat publikasi...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-users dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Leads</h2>
                      <p>Ringkasan inquiry dari Franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-lead-summary>
                  <li><span>Memuat leads...</span></li>
                </ul>
              </section>

              <section class="dash-panel dash-panel-wide">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-chart-line dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Premium Operations</h2>
                      <p>Funnel, metode pembayaran, dan info Premium terbaru.</p>
                    </div>
                  </div>
                </div>
                <div class="dash-premium-ops">
                  <ul class="dash-list dash-premium-funnel" data-premium-funnel>
                    <li><span>Memuat funnel Premium...</span></li>
                  </ul>
                  <form class="dash-payment-form" data-payment-method-form>
                    <input type="hidden" name="code" value="manual_bca" />
                    <input type="hidden" name="qris_image_url" />
                    <label>
                      <span>Label</span>
                      <input name="label" type="text" placeholder="Transfer BCA" />
                    </label>
                    <label>
                      <span>Tipe</span>
                      <select name="method_type">
                        <option value="bank_transfer">Bank transfer</option>
                        <option value="qris">Bank + QRIS</option>
                        <option value="ewallet">E-wallet</option>
                        <option value="other">Lainnya</option>
                      </select>
                    </label>
                    <label>
                      <span>Bank/provider</span>
                      <input name="provider" type="text" placeholder="BCA" />
                    </label>
                    <label>
                      <span>Atas nama</span>
                      <input name="account_name" type="text" placeholder="Nama rekening" />
                    </label>
                    <label>
                      <span>Nomor</span>
                      <input name="account_number" type="text" placeholder="Nomor rekening" />
                    </label>
                    <label>
                      <span>Upload QRIS</span>
                      <input name="qris_image" type="file" accept="image/jpeg,image/png,image/webp" />
                    </label>
                    <label>
                      <span>Label QRIS</span>
                      <input name="qris_image_alt" type="text" placeholder="QRIS pembayaran Premium" />
                    </label>
                    <div class="dash-payment-qris-preview is-wide" data-qris-preview hidden></div>
                    <label class="is-wide">
                      <span>Instruksi</span>
                      <textarea name="instructions" rows="2" placeholder="Instruksi singkat untuk pembayar"></textarea>
                    </label>
                    <button class="dash-icon-button dash-action-button is-primary" type="submit" aria-label="Simpan metode pembayaran" data-fr-tooltip="Simpan metode pembayaran">
                      <i class="fas fa-save" aria-hidden="true"></i>
                    </button>
                  </form>
                  <form class="dash-payment-form" data-premium-settings-form>
                    <label>
                      <span>Masa tenggang</span>
                      <input name="grace_period_days" type="number" min="0" max="30" step="1" placeholder="3" />
                    </label>
                    <label>
                      <span>Email harian</span>
                      <select name="grace_daily_email_enabled">
                        <option value="1">Aktif</option>
                        <option value="0">Nonaktif</option>
                      </select>
                    </label>
                    <label>
                      <span>Laporan tahunan</span>
                      <select name="annual_report_enabled">
                        <option value="1">Aktif</option>
                        <option value="0">Nonaktif</option>
                      </select>
                    </label>
                    <label>
                      <span>Diskon multi-brand</span>
                      <select name="multi_brand_discount_enabled">
                        <option value="0">Nonaktif</option>
                        <option value="1">Aktif</option>
                      </select>
                    </label>
                    <label>
                      <span>Diskon %</span>
                      <input name="multi_brand_discount_percent" type="number" min="0" max="90" step="1" placeholder="0" />
                    </label>
                    <label>
                      <span>Minimal brand</span>
                      <input name="multi_brand_min_owned_brands" type="number" min="2" max="50" step="1" placeholder="2" />
                    </label>
                    <label>
                      <span>Promo ribbon</span>
                      <select name="promo_enabled">
                        <option value="0">Nonaktif</option>
                        <option value="1">Aktif</option>
                      </select>
                    </label>
                    <label>
                      <span>Diskon event %</span>
                      <input name="promo_discount_percent" type="number" min="0" max="90" step="1" placeholder="0" />
                    </label>
                    <label>
                      <span>Nama event</span>
                      <input name="promo_label" type="text" placeholder="Promo Hari Kemerdekaan" />
                    </label>
                    <label>
                      <span>Bonus</span>
                      <input name="promo_bonus_text" type="text" placeholder="Contoh: profil artikel gratis" />
                    </label>
                    <label class="is-wide">
                      <span>Pesan ribbon</span>
                      <input name="promo_message" type="text" placeholder="Premium Network diskon spesial bulan ini." />
                    </label>
                    <label>
                      <span>CTA ribbon</span>
                      <input name="promo_cta_label" type="text" placeholder="Lihat Premium" />
                    </label>
                    <label>
                      <span>Link CTA</span>
                      <input name="promo_cta_url" type="text" placeholder="/premium/" />
                    </label>
                    <label>
                      <span>Mulai</span>
                      <input name="promo_starts_at" type="datetime-local" />
                    </label>
                    <label>
                      <span>Berakhir</span>
                      <input name="promo_ends_at" type="datetime-local" />
                    </label>
                    <button class="dash-icon-button dash-action-button is-primary" type="submit" aria-label="Simpan pengaturan Premium" data-fr-tooltip="Simpan pengaturan Premium">
                      <i class="fas fa-sliders-h" aria-hidden="true"></i>
                    </button>
                  </form>
                  <ul class="dash-list" data-premium-notifications>
                    <li><span>Memuat info Premium...</span></li>
                  </ul>
                  <ul class="dash-list" data-premium-reports>
                    <li><span>Memuat laporan Premium...</span></li>
                  </ul>
                  <ul class="dash-list" data-premium-expiring>
                    <li><span>Memuat renewal Premium...</span></li>
                  </ul>
                  <ul class="dash-list" data-premium-email-queue>
                    <li><span>Memuat antrean email...</span></li>
                  </ul>
                </div>
              </section>

              <section class="dash-panel dash-panel-wide">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-crown dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Premium Payments</h2>
                      <p>Konfirmasi transfer Premium yang perlu dicek.</p>
                    </div>
                  </div>
                </div>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Brand</th>
                        <th>Transfer</th>
                        <th>Pendaftar</th>
                        <th>Kesiapan</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody data-premium-payment-rows>
                      <tr><td colspan="5" class="dash-empty">Memuat konfirmasi Premium...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-heartbeat dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>System Health</h2>
                      <p>Koneksi akun, data, dan publikasi.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-system-health>
                  <li><span>Memuat health check...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-clipboard-list dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Staff Edit Policy</h2>
                      <p>Default: staff menyarankan edit, admin approve.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-edit-policy>
                  <li><strong>Auto approve</strong><span>Hanya berlaku jika admin membuat rule aktif untuk staff tertentu.</span></li>
                  <li><strong>Area kerja</strong><span>Dashboard ini hanya untuk franchisee.id.</span></li>
                </ul>
              </section>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/auth-clerk-debug.js" is:inline></script>
    <script src="/js/auth-clerk-ui.js" is:inline></script>
    <script src="/js/auth-clerk-core.js" is:inline></script>
    <script src="/js/auth-clerk.js" is:inline></script>
    <script src="/js/shared-tooltip.js" is:inline></script>
    <script src="/js/dashboard-utils.js" is:inline></script>
    <script src="/js/dashboard-premium-operations.js" is:inline></script>
    <script src="/js/dashboard-review.js" is:inline></script>
    <script src="/js/dashboard-operations.js" is:inline></script>
    <script src="/js/dashboard-admin.js" is:inline></script>
  </body>
</html>
