---
export const prerender = true;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Dashboard Operasional - Franchisee.id</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/css/frontend.min.css">
    <link rel="stylesheet" href="/css/auth-clerk.css">
    <style>
      :root {
        --dash-ink: #171717;
        --dash-muted: #646464;
        --dash-line: #e5e5e5;
        --dash-soft: #f7f7f7;
        --dash-accent: #f0ca00;
        --dash-accent-dark: #5d4500;
        --dash-good: #0f6b3d;
        --dash-warn: #8a5a00;
        --dash-bad: #a42424;
      }
      body {
        margin: 0;
        background: #f2f2f2;
        color: var(--dash-ink);
        font-family: Outfit, "DM Sans", Arial, sans-serif;
      }
      .dash-shell {
        min-height: 100vh;
      }
      .dash-header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--dash-line);
        background: rgba(255, 255, 255, 0.96);
      }
      .dash-header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      .dash-title h1 {
        margin: 0;
        font-size: 22px;
        line-height: 1.2;
      }
      .dash-title p {
        margin: 3px 0 0;
        color: var(--dash-muted);
        font-size: 13px;
      }
      .dash-user {
        color: var(--dash-muted);
        font-size: 13px;
        text-align: right;
      }
      .dash-main {
        max-width: 1280px;
        margin: 0 auto;
        padding: 22px 20px 44px;
      }
      .dash-main[data-dashboard-protected="locked"] .dash-grid,
      .dash-main[data-dashboard-protected="locked"] .dash-layout {
        display: none !important;
      }
      .dash-login-panel {
        max-width: 560px;
        margin: 20px auto 0;
      }
      .dash-login-panel[hidden] {
        display: none !important;
      }
      .dash-alert {
        margin-bottom: 16px;
        border: 1px solid #ead57e;
        border-left: 4px solid var(--dash-accent);
        background: #fff9df;
        padding: 14px 16px;
        color: #352800;
        font-size: 14px;
      }
      .dash-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
      }
      .dash-card,
      .dash-panel {
        border: 1px solid var(--dash-line);
        background: #ffffff;
      }
      .dash-card {
        padding: 15px;
      }
      .dash-card span {
        display: block;
        color: var(--dash-muted);
        font-size: 12px;
        font-weight: 700;
      }
      .dash-card strong {
        display: block;
        margin-top: 8px;
        font-size: 26px;
        line-height: 1;
      }
      .dash-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.8fr) minmax(320px, 0.9fr);
        gap: 16px;
        margin-top: 16px;
      }
      .dash-panel {
        min-width: 0;
      }
      .dash-panel-header {
        padding: 14px 16px;
        border-bottom: 1px solid var(--dash-line);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }
      .dash-panel-header h2 {
        margin: 0;
        font-size: 16px;
      }
      .dash-panel-header p {
        margin: 3px 0 0;
        color: var(--dash-muted);
        font-size: 12px;
      }
      .dash-table-wrap {
        overflow-x: auto;
      }
      .dash-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      .dash-table th,
      .dash-table td {
        border-bottom: 1px solid var(--dash-line);
        padding: 10px 12px;
        text-align: left;
        vertical-align: top;
      }
      .dash-table th {
        color: var(--dash-muted);
        font-size: 11px;
        text-transform: uppercase;
      }
      .dash-table a {
        color: #111111;
        font-weight: 700;
      }
      .dash-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .dash-form {
        display: grid;
        grid-template-columns: minmax(220px, 0.7fr) minmax(0, 1fr);
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--dash-line);
      }
      .dash-form label {
        display: grid;
        gap: 5px;
        color: var(--dash-muted);
        font-size: 12px;
        font-weight: 800;
      }
      .dash-form select,
      .dash-form input,
      .dash-form textarea {
        width: 100%;
        min-height: 38px;
        border: 1px solid #d7d7d7;
        border-radius: 4px;
        background: #ffffff;
        color: #111111;
        padding: 8px 10px;
        font: inherit;
        font-size: 13px;
      }
      .dash-form textarea {
        min-height: 92px;
        resize: vertical;
        font-family: Consolas, "Courier New", monospace;
      }
      .dash-form .dash-form-wide {
        grid-column: 1 / -1;
      }
      .dash-button {
        min-height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #151515;
        border-radius: 4px;
        background: #151515;
        color: #ffffff !important;
        padding: 7px 10px;
        font-size: 12px;
        font-weight: 800;
        text-decoration: none !important;
        cursor: pointer;
      }
      .dash-button.secondary {
        border-color: #dedede;
        background: #f7f7f7;
        color: #111111 !important;
      }
      .dash-badge {
        display: inline-flex;
        align-items: center;
        min-height: 22px;
        border-radius: 999px;
        padding: 3px 8px;
        background: #fff3bf;
        color: var(--dash-accent-dark);
        font-size: 11px;
        font-weight: 800;
      }
      .dash-badge.good {
        background: #dff3e8;
        color: var(--dash-good);
      }
      .dash-badge.bad {
        background: #fde3e3;
        color: var(--dash-bad);
      }
      .dash-stack {
        display: grid;
        gap: 16px;
      }
      .dash-list {
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .dash-list li {
        padding: 11px 16px;
        border-bottom: 1px solid var(--dash-line);
      }
      .dash-list strong {
        display: block;
        font-size: 13px;
      }
      .dash-list span {
        display: block;
        margin-top: 3px;
        color: var(--dash-muted);
        font-size: 12px;
      }
      .dash-empty,
      .dash-loading {
        padding: 18px 16px;
        color: var(--dash-muted);
        font-size: 13px;
      }
      .dash-error {
        border-color: #f1b1b1;
        background: #fff1f1;
        color: var(--dash-bad);
      }
      .dash-debug-panel {
        margin-top: 14px;
        border: 1px solid #d7d7d7;
        background: #ffffff;
      }
      .dash-debug-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border-bottom: 1px solid var(--dash-line);
      }
      .dash-debug-head strong {
        font-size: 13px;
      }
      .dash-debug-head span,
      .dash-debug-summary {
        color: var(--dash-muted);
        font-size: 12px;
      }
      .dash-debug-actions {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .dash-icon-button {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #dedede;
        border-radius: 4px;
        background: #f7f7f7;
        color: #111111;
        cursor: pointer;
      }
      .dash-icon-button:hover,
      .dash-icon-button:focus {
        border-color: #151515;
        background: #ffffff;
      }
      .dash-icon-button svg {
        width: 17px;
        height: 17px;
      }
      .dash-debug-body {
        display: grid;
        gap: 10px;
        padding: 12px 14px;
      }
      .dash-debug-output {
        max-height: 360px;
        margin: 0;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-word;
        border: 1px solid #ededed;
        background: #f8f8f8;
        color: #171717;
        padding: 10px;
        font: 12px/1.45 Consolas, "Courier New", monospace;
      }
      .dash-muted {
        color: var(--dash-muted);
        font-size: 12px;
      }
      @media (max-width: 980px) {
        .dash-grid,
        .dash-layout {
          grid-template-columns: 1fr 1fr;
        }
      }
      @media (max-width: 720px) {
        .dash-header-inner,
        .dash-layout,
        .dash-grid {
          display: block;
        }
        .dash-card,
        .dash-panel {
          margin-bottom: 12px;
        }
        .dash-user {
          margin-top: 8px;
          text-align: left;
        }
        .dash-form {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="dash-shell">
      <header class="dash-header">
        <div class="dash-header-inner">
          <div class="dash-title">
            <h1>Dashboard Operasional</h1>
            <p>Franchisee.id site scope. Data langsung dari D1.</p>
          </div>
          <div class="dash-user" data-dashboard-user>Memuat sesi...</div>
        </div>
      </header>

      <main class="dash-main" data-dashboard-protected="locked">
        <div class="dash-alert" data-dashboard-status>Memeriksa akses admin/staff...</div>

        <section class="dash-login-panel" data-dashboard-login aria-label="Login admin dan staff">
          <div id="franchise-auth-root" data-auth-mode="login" data-auth-variant="staff" data-auth-next="/dashboard/"></div>
          <div class="dash-debug-panel" data-auth-debug>
            <div class="dash-debug-head">
              <div>
                <strong>Auth Debug</strong>
                <span>Safe to screenshot: token values are masked.</span>
              </div>
              <div class="dash-debug-actions">
                <button class="dash-icon-button" type="button" data-auth-debug-copy aria-label="Copy auth debug" title="Copy auth debug">
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M8 7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2V7Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M4 15V4a2 2 0 0 1 2-2h9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </button>
                <button class="dash-button secondary" type="button" data-auth-debug-refresh>Refresh</button>
              </div>
            </div>
            <div class="dash-debug-body">
              <div class="dash-debug-summary" data-auth-debug-summary>Menunggu auth runtime...</div>
              <pre class="dash-debug-output" data-auth-debug-output>{}</pre>
            </div>
          </div>
        </section>

        <section class="dash-grid" aria-label="Ringkasan dashboard">
          <div class="dash-card"><span>Total listing</span><strong data-metric="total_listings">-</strong></div>
          <div class="dash-card"><span>Belum diklaim</span><strong data-metric="unclaimed_listings">-</strong></div>
          <div class="dash-card"><span>Terverifikasi</span><strong data-metric="verified_listings">-</strong></div>
          <div class="dash-card"><span>Pending publish</span><strong data-metric="pending_publish">-</strong></div>
        </section>

        <section class="dash-layout">
          <div class="dash-stack">
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Unclaimed Outreach</h2>
                  <p>WhatsApp memakai nomor personal staff melalui link wa.me.</p>
                </div>
                <span class="dash-badge" data-outreach-count>-</span>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kontak</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-outreach-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat antrean outreach...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Data Quality</h2>
                  <p>Prioritas listing yang perlu dibersihkan.</p>
                </div>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kategori</th>
                      <th>Warning</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-quality-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat quality checks...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Listing Edit Suggestions</h2>
                  <p>Staff menyarankan edit lewat JSON diff; admin approve sebelum masuk D1.</p>
                </div>
                <span class="dash-badge" data-edit-count>-</span>
              </div>
              <form class="dash-form" data-edit-form>
                <label>
                  Listing
                  <select data-listing-select required>
                    <option value="">Memuat listing...</option>
                  </select>
                </label>
                <label>
                  Reason
                  <input type="text" data-edit-reason maxlength="1200" placeholder="Contoh: nomor kontak publik salah">
                </label>
                <label class="dash-form-wide">
                  JSON diff
                  <textarea data-edit-json spellcheck="false" required placeholder="Contoh: phone dan office_address dalam JSON diff"></textarea>
                </label>
                <div class="dash-form-wide dash-actions">
                  <button class="dash-button" type="submit">Submit Suggestion</button>
                  <span class="dash-muted" data-edit-help>Field yang boleh diedit mengikuti whitelist dashboard di API.</span>
                </div>
              </form>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Diff</th>
                      <th>Reason</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-edit-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat edit suggestions...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </div>

          <aside class="dash-stack">
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Publish Queue</h2>
                  <p>Status static rebuild untuk franchisee.id.</p>
                </div>
              </div>
              <ul class="dash-list" data-publish-state>
                <li><span>Memuat publish state...</span></li>
              </ul>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Claim Review</h2>
                  <p>Admin menyetujui claim; staff hanya membantu review.</p>
                </div>
              </div>
              <ul class="dash-list" data-claim-rows>
                <li><span>Memuat claim pending...</span></li>
              </ul>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Leads</h2>
                  <p>Ringkasan inquiry dari Franchisee.id.</p>
                </div>
              </div>
              <ul class="dash-list" data-lead-summary>
                <li><span>Memuat leads...</span></li>
              </ul>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>System Health</h2>
                  <p>D1, Clerk, dan publish workflow.</p>
                </div>
              </div>
              <ul class="dash-list" data-system-health>
                <li><span>Memuat health check...</span></li>
              </ul>
            </section>

            <section class="dash-panel">
              <div class="dash-panel-header">
                <div>
                  <h2>Staff Edit Policy</h2>
                  <p>Default: staff menyarankan edit, admin approve.</p>
                </div>
              </div>
              <ul class="dash-list" data-edit-policy>
                <li><strong>Auto approve</strong><span>Hanya berlaku jika admin membuat rule aktif untuk staff tertentu.</span></li>
                <li><strong>Site scope</strong><span>Dashboard ini hanya untuk franchisee.id; centralized dashboard dibuat nanti.</span></li>
              </ul>
            </section>
          </aside>
        </section>
      </main>
    </div>

    <script src="/js/auth-clerk-debug.js" is:inline></script>
    <script src="/js/auth-clerk.js" is:inline></script>
    <script src="/js/dashboard-admin.js" is:inline></script>
  </body>
</html>
