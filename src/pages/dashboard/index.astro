---
export const prerender = true;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Dashboard Operasional - Franchisee.id</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/css/frontend.min.css">
    <link rel="stylesheet" href="/css/auth-clerk.css">
    <link rel="stylesheet" href="/css/dashboard.css">
  </head>
  <body>
    <div class="dash-shell">
      <header class="dash-header">
        <div class="dash-header-inner">
          <div class="dash-title">
            <h1>Dashboard Operasional</h1>
            <p>Franchisee.id site scope. Data langsung dari D1.</p>
          </div>
          <div class="dash-user" data-dashboard-user>Memuat sesi...</div>
        </div>
      </header>

      <main class="dash-main" data-dashboard-protected="locked">
        <div class="dash-alert" data-dashboard-status>Memeriksa akses admin/staff...</div>

        <section class="dash-login-panel" data-dashboard-login aria-label="Login admin dan staff">
          <div id="franchise-auth-root" data-auth-mode="login" data-auth-variant="staff" data-auth-next="/dashboard/"></div>
          <div class="dash-debug-panel" data-auth-debug>
            <div class="dash-debug-head">
              <div>
                <strong>Auth Debug</strong>
                <span>Safe to screenshot: token values are masked.</span>
              </div>
              <div class="dash-debug-actions">
                <button class="dash-icon-button" type="button" data-auth-debug-copy aria-label="Copy auth debug" title="Copy auth debug">
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M8 7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2V7Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M4 15V4a2 2 0 0 1 2-2h9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </button>
                <button class="dash-button secondary" type="button" data-auth-debug-refresh>Refresh</button>
              </div>
            </div>
            <div class="dash-debug-body">
              <div class="dash-debug-summary" data-auth-debug-summary>Menunggu auth runtime...</div>
              <pre class="dash-debug-output" data-auth-debug-output>{}</pre>
            </div>
          </div>
        </section>

        <section class="dash-grid" aria-label="Ringkasan dashboard">
          <div class="dash-card"><span>Total listing</span><strong data-metric="total_listings">-</strong></div>
          <div class="dash-card"><span>Belum diklaim</span><strong data-metric="unclaimed_listings">-</strong></div>
          <div class="dash-card"><span>Terverifikasi</span><strong data-metric="verified_listings">-</strong></div>
          <div class="dash-card"><span>Pending publish</span><strong data-metric="pending_publish">-</strong></div>
        </section>

        <nav class="dash-tabs" role="tablist" aria-label="Dashboard sections" data-dashboard-tabs>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-outreach" aria-controls="dash-panel-outreach" aria-selected="true" data-dashboard-tab="outreach">
            <svg class="dash-tab-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.4a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6A8.4 8.4 0 0 1 12.5 3H13a8 8 0 0 1 8 8v.5Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            Outreach
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-quality" aria-controls="dash-panel-quality" aria-selected="false" data-dashboard-tab="quality">
            <svg class="dash-tab-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 12l2 2 4-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            Data Quality
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-review" aria-controls="dash-panel-review" aria-selected="false" data-dashboard-tab="review">
            <svg class="dash-tab-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M14 2v6h6M9 15l2 2 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Review
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-operations" aria-controls="dash-panel-operations" aria-selected="false" data-dashboard-tab="operations">
            <svg class="dash-tab-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.6-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.9.3h.1A1.7 1.7 0 0 0 10 3.1V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.6h.1a1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.9v.1A1.7 1.7 0 0 0 20.9 10H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            Operations
          </button>
        </nav>

        <section class="dash-tab-panels">
          <section class="dash-tab-panel" id="dash-panel-outreach" role="tabpanel" aria-labelledby="dash-tab-outreach" data-dashboard-panel="outreach">
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                  <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.4a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6A8.4 8.4 0 0 1 12.5 3H13a8 8 0 0 1 8 8v.5Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
                  <div>
                    <h2>Unclaimed Outreach</h2>
                    <p>WhatsApp memakai nomor personal staff melalui link wa.me.</p>
                  </div>
                </div>
                <span class="dash-badge" data-outreach-count>-</span>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kontak</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-outreach-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat antrean outreach...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-quality" role="tabpanel" aria-labelledby="dash-tab-quality" data-dashboard-panel="quality" hidden>
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                  <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 12l2 2 4-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                  <div>
                    <h2>Data Quality</h2>
                    <p>Prioritas listing yang perlu dibersihkan.</p>
                  </div>
                </div>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kategori</th>
                      <th>Warning</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-quality-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat quality checks...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-review" role="tabpanel" aria-labelledby="dash-tab-review" data-dashboard-panel="review" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 20h9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
                    <div>
                      <h2>Listing Edit Suggestions</h2>
                      <p>Staff menyarankan edit lewat JSON diff; admin approve sebelum masuk D1.</p>
                    </div>
                  </div>
                  <span class="dash-badge" data-edit-count>-</span>
                </div>
                <form class="dash-form" data-edit-form>
                  <label>
                    Listing
                    <select data-listing-select required>
                      <option value="">Memuat listing...</option>
                    </select>
                  </label>
                  <label>
                    Reason
                    <input type="text" data-edit-reason maxlength="1200" placeholder="Contoh: nomor kontak publik salah">
                  </label>
                  <label class="dash-form-wide">
                    JSON diff
                    <textarea data-edit-json spellcheck="false" required placeholder="Contoh: phone dan office_address dalam JSON diff"></textarea>
                  </label>
                  <div class="dash-form-wide dash-actions">
                    <button class="dash-button" type="submit">Submit Suggestion</button>
                    <span class="dash-muted" data-edit-help>Field yang boleh diedit mengikuti whitelist dashboard di API.</span>
                  </div>
                </form>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Brand</th>
                        <th>Diff</th>
                        <th>Reason</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody data-edit-rows>
                      <tr><td colspan="4" class="dash-loading">Memuat edit suggestions...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 3l7 4v5c0 4.4-2.9 7.4-7 9-4.1-1.6-7-4.6-7-9V7l7-4Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div>
                      <h2>Claim Review</h2>
                      <p>Admin menyetujui claim; staff hanya membantu review.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-claim-rows>
                  <li><span>Memuat claim pending...</span></li>
                </ul>
              </section>
            </div>
          </section>

          <section class="dash-tab-panel" id="dash-panel-operations" role="tabpanel" aria-labelledby="dash-tab-operations" data-dashboard-panel="operations" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M21 12a9 9 0 0 1-9 9 9.4 9.4 0 0 1-6.4-2.5L3 21l.8-5.2A9 9 0 1 1 21 12Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div>
                      <h2>Publish Queue</h2>
                      <p>Status static rebuild untuk franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-publish-state>
                  <li><span>Memuat publish state...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <div>
                      <h2>Leads</h2>
                      <p>Ringkasan inquiry dari Franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-lead-summary>
                  <li><span>Memuat leads...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M20 13c0 5-3.5 7-8 9-4.5-2-8-4-8-9V5l8-3 8 3v8Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 12l2 2 4-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div>
                      <h2>System Health</h2>
                      <p>D1, Clerk, dan publish workflow.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-system-health>
                  <li><span>Memuat health check...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <svg class="dash-section-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 21V5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v16" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M8 7h8M8 11h8M8 15h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <div>
                      <h2>Staff Edit Policy</h2>
                      <p>Default: staff menyarankan edit, admin approve.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-edit-policy>
                  <li><strong>Auto approve</strong><span>Hanya berlaku jika admin membuat rule aktif untuk staff tertentu.</span></li>
                  <li><strong>Site scope</strong><span>Dashboard ini hanya untuk franchisee.id; centralized dashboard dibuat nanti.</span></li>
                </ul>
              </section>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/auth-clerk-debug.js" is:inline></script>
    <script src="/js/auth-clerk.js" is:inline></script>
    <script src="/js/dashboard-admin.js" is:inline></script>
  </body>
</html>
