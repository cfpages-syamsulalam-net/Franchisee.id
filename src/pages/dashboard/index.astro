---
export const prerender = true;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>Dashboard Operasional - Franchisee.id</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/css/frontend.min.css">
    <link rel="stylesheet" href="/wp-content/plugins/elementor/assets/lib/font-awesome/css/all.min.css?ver=3.32.3">
    <link rel="stylesheet" href="/css/auth-clerk.css">
    <link rel="stylesheet" href="/css/shared-tooltip.css">
    <link rel="stylesheet" href="/css/dashboard.css">
  </head>
  <body>
    <div class="dash-shell">
      <header class="dash-header">
        <div class="dash-header-inner">
          <div class="dash-title">
            <h1>Dashboard Operasional</h1>
            <p>Ruang kerja internal Franchisee.id.</p>
          </div>
          <div class="dash-user" data-dashboard-user>Memuat sesi...</div>
        </div>
      </header>

      <main class="dash-main" data-dashboard-protected="locked">
        <div class="dash-alert" data-dashboard-status>Memeriksa akses admin/staff...</div>

        <section class="dash-login-panel" data-dashboard-login aria-label="Login admin dan staff">
          <div id="franchise-auth-root" data-auth-mode="login" data-auth-variant="staff" data-auth-next="/dashboard/"></div>
          <div class="dash-debug-panel" data-auth-debug>
            <div class="dash-debug-head">
              <div>
                <strong>Auth Debug</strong>
                <span>Safe to screenshot: token values are masked.</span>
              </div>
              <div class="dash-debug-actions">
                <button class="dash-icon-button" type="button" data-auth-debug-copy aria-label="Salin debug login" data-fr-tooltip="Salin debug login">
                  <i class="fas fa-copy" aria-hidden="true"></i>
                </button>
                <button class="dash-button secondary" type="button" data-auth-debug-refresh>Refresh</button>
              </div>
            </div>
            <div class="dash-debug-body">
              <div class="dash-debug-summary" data-auth-debug-summary>Menunggu auth runtime...</div>
              <pre class="dash-debug-output" data-auth-debug-output>{}</pre>
            </div>
          </div>
        </section>

        <section class="dash-grid" aria-label="Ringkasan dashboard">
          <div class="dash-card"><span>Total listing</span><strong data-metric="total_listings">-</strong></div>
          <div class="dash-card"><span>Belum diklaim</span><strong data-metric="unclaimed_listings">-</strong></div>
          <div class="dash-card"><span>Terverifikasi</span><strong data-metric="verified_listings">-</strong></div>
          <div class="dash-card"><span>Pending publish</span><strong data-metric="pending_publish">-</strong></div>
        </section>

        <nav class="dash-tabs" role="tablist" aria-label="Dashboard sections" data-dashboard-tabs>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-outreach" aria-controls="dash-panel-outreach" aria-selected="true" data-dashboard-tab="outreach">
            <i class="fas fa-comments dash-tab-icon" aria-hidden="true"></i>
            Outreach
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-quality" aria-controls="dash-panel-quality" aria-selected="false" data-dashboard-tab="quality">
            <i class="fas fa-check-circle dash-tab-icon" aria-hidden="true"></i>
            Data Quality
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-review" aria-controls="dash-panel-review" aria-selected="false" data-dashboard-tab="review">
            <i class="fas fa-clipboard-check dash-tab-icon" aria-hidden="true"></i>
            Review
          </button>
          <button class="dash-tab" type="button" role="tab" id="dash-tab-operations" aria-controls="dash-panel-operations" aria-selected="false" data-dashboard-tab="operations">
            <i class="fas fa-cogs dash-tab-icon" aria-hidden="true"></i>
            Operations
          </button>
        </nav>

        <section class="dash-tab-panels">
          <section class="dash-tab-panel" id="dash-panel-outreach" role="tabpanel" aria-labelledby="dash-tab-outreach" data-dashboard-panel="outreach">
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                  <i class="fas fa-comments dash-section-icon" aria-hidden="true"></i>
                  <div>
                    <h2>Unclaimed Outreach</h2>
                    <p>WhatsApp memakai nomor personal staff melalui link wa.me.</p>
                  </div>
                </div>
                <span class="dash-badge" data-outreach-count>-</span>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kontak</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-outreach-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat antrean outreach...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-quality" role="tabpanel" aria-labelledby="dash-tab-quality" data-dashboard-panel="quality" hidden>
            <section class="dash-panel">
              <div class="dash-panel-header">
                <div class="dash-panel-title">
                    <i class="fas fa-check-circle dash-section-icon" aria-hidden="true"></i>
                  <div>
                    <h2>Data Quality</h2>
                    <p>Prioritas listing yang perlu dibersihkan.</p>
                  </div>
                </div>
                <div class="dash-actions">
                  <button class="dash-button secondary" type="button" data-refresh-quality>
                    <i class="fas fa-sync-alt" aria-hidden="true"></i>
                    Refresh checks
                  </button>
                </div>
              </div>
              <div class="dash-table-wrap">
                <table class="dash-table">
                  <thead>
                    <tr>
                      <th>Brand</th>
                      <th>Kategori</th>
                      <th>Warning</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody data-quality-rows>
                    <tr><td colspan="4" class="dash-loading">Memuat quality checks...</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </section>

          <section class="dash-tab-panel" id="dash-panel-review" role="tabpanel" aria-labelledby="dash-tab-review" data-dashboard-panel="review" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-edit dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Listing Edit Suggestions</h2>
                      <p>Staff menyiapkan perubahan; admin menyetujui sebelum tampil.</p>
                    </div>
                  </div>
                  <span class="dash-badge" data-edit-count>-</span>
                </div>
                <form class="dash-form" data-edit-form>
                  <label>
                    Listing
                    <select data-listing-select required>
                      <option value="">Memuat listing...</option>
                    </select>
                  </label>
                  <label>
                    Reason
                    <input type="text" data-edit-reason maxlength="1200" placeholder="Contoh: nomor kontak publik salah">
                  </label>
                  <div class="dash-form-wide dash-field-editor">
                    <div class="dash-field-editor-head">
                      <div>
                        <strong>Perubahan field</strong>
                        <span>Pilih field, isi nilai baru, lalu kirim untuk review.</span>
                      </div>
                      <button class="dash-button secondary" type="button" data-add-edit-field>
                        <i class="fas fa-plus" aria-hidden="true"></i>
                        Tambah field
                      </button>
                    </div>
                    <div class="dash-field-list" data-edit-field-list></div>
                  </div>
                  <div class="dash-form-wide dash-actions">
                    <button class="dash-button" type="submit">
                      <i class="fas fa-paper-plane" aria-hidden="true"></i>
                      Submit Suggestion
                    </button>
                    <span class="dash-muted" data-edit-help>Perubahan akan masuk review admin kecuali akun ini punya izin approve langsung.</span>
                  </div>
                </form>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Brand</th>
                        <th>Diff</th>
                        <th>Reason</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody data-edit-rows>
                      <tr><td colspan="4" class="dash-loading">Memuat edit suggestions...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-shield-alt dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Claim Review</h2>
                      <p>Admin menyetujui claim; staff hanya membantu review.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-claim-rows>
                  <li><span>Memuat claim pending...</span></li>
                </ul>
              </section>
            </div>
          </section>

          <section class="dash-tab-panel" id="dash-panel-operations" role="tabpanel" aria-labelledby="dash-tab-operations" data-dashboard-panel="operations" hidden>
            <div class="dash-panel-grid two">
              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-sync-alt dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Publish Queue</h2>
                      <p>Status pembaruan halaman franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-publish-state>
                  <li><span>Memuat publish state...</span></li>
                </ul>
              </section>

              <section class="dash-panel dash-panel-wide">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-network-wired dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Publikasi Network</h2>
                      <p>Atur tampil/sembunyi listing di situs yang tersedia.</p>
                    </div>
                  </div>
                </div>
                <div class="dash-table-wrap">
                  <table class="dash-table">
                    <thead>
                      <tr>
                        <th>Listing</th>
                        <th>Status per situs</th>
                      </tr>
                    </thead>
                    <tbody data-publication-rows>
                      <tr><td colspan="2" class="dash-empty">Memuat publikasi...</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-users dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Leads</h2>
                      <p>Ringkasan inquiry dari Franchisee.id.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-lead-summary>
                  <li><span>Memuat leads...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-heartbeat dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>System Health</h2>
                      <p>Koneksi akun, data, dan publikasi.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-system-health>
                  <li><span>Memuat health check...</span></li>
                </ul>
              </section>

              <section class="dash-panel">
                <div class="dash-panel-header">
                  <div class="dash-panel-title">
                    <i class="fas fa-clipboard-list dash-section-icon" aria-hidden="true"></i>
                    <div>
                      <h2>Staff Edit Policy</h2>
                      <p>Default: staff menyarankan edit, admin approve.</p>
                    </div>
                  </div>
                </div>
                <ul class="dash-list" data-edit-policy>
                  <li><strong>Auto approve</strong><span>Hanya berlaku jika admin membuat rule aktif untuk staff tertentu.</span></li>
                  <li><strong>Area kerja</strong><span>Dashboard ini hanya untuk franchisee.id.</span></li>
                </ul>
              </section>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/auth-clerk-debug.js" is:inline></script>
    <script src="/js/auth-clerk-ui.js" is:inline></script>
    <script src="/js/auth-clerk.js" is:inline></script>
    <script src="/js/shared-tooltip.js" is:inline></script>
    <script src="/js/dashboard-admin.js" is:inline></script>
  </body>
</html>
