<section class="dash-tab-panel" id="dash-panel-publication" role="tabpanel" aria-labelledby="dash-tab-publication" data-dashboard-panel="publication" hidden>
  <section class="dash-panel dash-publication-panel">
    <div class="dash-panel-header">
      <div class="dash-panel-title">
        <i class="fas fa-network-wired dash-section-icon" aria-hidden="true"></i>
        <div>
          <h2>Publikasi Network</h2>
          <p>Atur tampil/sembunyi listing di situs yang tersedia.</p>
        </div>
      </div>
      <span class="dash-badge" data-publication-count>-</span>
    </div>
    <div class="dash-publication-intro">
      <div>
        <strong>Status distribusi listing</strong>
        <span>Setiap kartu adalah satu listing. Ubah status per situs untuk mengontrol apakah listing tampil, disembunyikan, atau disiapkan sebagai draft.</span>
      </div>
      <div class="dash-publication-legend" aria-label="Legenda status publikasi">
        <span class="dash-publication-status is-published">Published</span>
        <span class="dash-publication-status is-draft">Draft</span>
        <span class="dash-publication-status is-hidden">Hidden</span>
        <span class="dash-publication-status is-archived">Archived</span>
      </div>
    </div>
    <div class="dash-publication-list" data-publication-rows>
      <div class="dash-loading">Memuat publikasi...</div>
    </div>
  </section>
</section>
