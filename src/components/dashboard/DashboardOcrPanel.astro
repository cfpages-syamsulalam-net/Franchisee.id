            <input name="api_key" type="password" maxlength="2000" autocomplete="new-password" placeholder="Kosongkan untuk mempertahankan" />
            <small data-ocr-help="api_key">Kolom kosong mempertahankan key lama.</small>
          </label>
          <label data-ocr-field="api_secret">
            <span class="dash-field-label-row">
              <span data-ocr-label="api_secret">API secret</span>
              <span class="dash-credential-badge" data-ocr-key-state="api_secret"></span>
            </span>
            <input name="api_secret" type="password" maxlength="4000" autocomplete="new-password" placeholder="Hanya untuk provider yang memerlukan" />
            <small data-ocr-help="api_secret">Kolom kosong mempertahankan secret lama.</small>
          </label>
          <label data-ocr-field="account_id">
            <span data-ocr-label="account_id">Account / project / client ID</span>
            <input name="account_id" type="text" maxlength="240" />
            <small data-ocr-help="account_id">Isi hanya jika provider membutuhkannya.</small>
          </label>
          <label data-ocr-field="region">
            <span data-ocr-label="region">Region</span>
            <input name="region" type="text" maxlength="120" placeholder="Contoh: ap-southeast-1" />
            <small data-ocr-help="region">Contoh: ap-southeast-1.</small>
          </label>
          <label class="dash-form-wide" data-ocr-field="endpoint_url">
            <span data-ocr-label="endpoint_url">Endpoint HTTPS</span>
            <input name="endpoint_url" type="text" maxlength="500" placeholder="https://..." />
            <small data-ocr-help="endpoint_url">Gunakan endpoint resource dari provider.</small>
          </label>
          <label data-ocr-field="model">
            <span data-ocr-label="model">Model / operasi</span>
            <input name="model" type="text" maxlength="240" />
            <small data-ocr-help="model">Gunakan default jika tidak yakin.</small>
          </label>
          <label class="dash-check-row" data-ocr-field="clear_api_key">
            <input name="clear_api_key" type="checkbox" />
            Hapus API key tersimpan
          </label>
          <label class="dash-check-row" data-ocr-field="clear_api_secret">
            <input name="clear_api_secret" type="checkbox" />
            Hapus API secret tersimpan
